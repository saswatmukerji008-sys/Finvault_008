<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FinVault Dashboard</title>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: Arial, sans-serif;
      background: #f8fafc;
      color: #0f172a;
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px;
    }

    .topbar {
      background: linear-gradient(135deg, #0f172a, #1d4ed8);
      color: white;
      padding: 24px;
      border-radius: 20px;
      margin-bottom: 24px;
    }

    .topbar h1 {
      font-size: 36px;
      margin-bottom: 8px;
    }

    .topbar p {
      color: #dbeafe;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
      margin-bottom: 24px;
    }

    .card {
      background: white;
      border-radius: 18px;
      padding: 22px;
      box-shadow: 0 4px 14px rgba(0,0,0,0.08);
    }

    .card h2 {
      font-size: 20px;
      margin-bottom: 10px;
      color: #1e3a8a;
    }

    .card p {
      color: #475569;
      font-size: 15px;
      line-height: 1.6;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 20px;
      margin-bottom: 24px;
    }

    .stat-box {
      background: white;
      padding: 20px;
      border-radius: 18px;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
    }

    .stat-box h3 {
      font-size: 14px;
      color: #475569;
      margin-bottom: 8px;
    }

    .stat-box p {
      font-size: 28px;
      font-weight: bold;
    }

    .section-title {
      font-size: 28px;
      margin: 28px 0 18px;
    }

    .button-row {
      margin-top: 10px;
    }

    .btn {
      display: inline-block;
      background: #2563eb;
      color: white;
      text-decoration: none;
      padding: 12px 18px;
      border-radius: 12px;
      font-weight: bold;
    }

    .btn:hover {
      background: #1d4ed8;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="topbar">
      <h1>FinVault Dashboard</h1>
      <p>Welcome to your personal finance dashboard.</p>
    </div>

    <div class="stats">
      <div class="stat-box">
        <h3>Monthly Income</h3>
        <p>₹1,20,000</p>
      </div>
      <div class="stat-box">
        <h3>Monthly Expenses</h3>
        <p>₹52,000</p>
      </div>
      <div class="stat-box">
        <h3>Total Savings</h3>
        <p>₹4,80,000</p>
      </div>
      <div class="stat-box">
        <h3>Investments</h3>
        <p>₹6,20,000</p>
      </div>
    </div>

    <h2 class="section-title">Your Features</h2>

    <div class="grid">
      <div class="card">
        <h2>Document Vault</h2>
        <p>Store salary slips, Form 16, bank statements, insurance, and loan documents.</p>
      </div>

      <div class="card">
        <h2>Expense Tracker</h2>
        <p>Track rent, food, utilities, EMI, shopping, and monthly spending.</p>
      </div>

      <div class="card">
        <h2>Investment Portfolio</h2>
        <p>View your mutual funds, SIPs, stocks, gold, and crypto in one place.</p>
      </div>

      <div class="card">
        <h2>Calculators</h2>
        <p>Use EMI, SIP, tax, FD/RD, and savings goal calculators.</p>
      </div>

      <div class="card">
        <h2>Finance News</h2>
        <p>Read useful personal finance news for India.</p>
      </div>

      <div class="card">
        <h2>Profile</h2>
        <p>Manage your account details and preferences.</p>
      </div>
    </div>

    <div class="button-row">
      <a class="btn" href="index.html">Back to Home</a>
    </div>
  </div>
</body>
</html>
